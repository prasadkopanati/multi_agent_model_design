# Agent selection per stage
# Possible values: claude, opencode, gemini, openclaude
AGENT_SPEC=claude
AGENT_PLAN=claude
AGENT_BUILD=opencode
AGENT_TEST=opencode
AGENT_REVIEW=claude
AGENT_FINISH=gemini
AGENT_FAILURE=claude

# Finish stage delivery action
# pr      — create a pull request against main (default)
# merge   — merge the branch directly into main
# keep    — push the branch without merging or creating a PR
# discard — delete the branch (prints what will be lost before deleting)
FINISH_ACTION=pr

# Git remote URL — only needed when agenticspiq initializes git (no .git in workspace).
# If the workspace already has a git repo with a remote configured, leave this unset.
# When set, scaffold.js adds this as 'origin' on first run (or any run where origin is missing).
# GIT_REMOTE_URL=https://github.com/yourorg/yourrepo.git

# Model selection per agent CLI
# Claude Code model (claude --model <value>)
CLAUDE_MODEL=sonnet

# OpenClaude model (openclaude --model <value>)
OPENCLAUDE_MODEL=sonnet

# OpenCode model (opencode --model <value>)
OPENCODE_MODEL=opencode/qwen3.5-plus

# Gemini model (gemini --model <value>)
GEMINI_MODEL=gemini-2.5-flash-preview

# API keys (required by the respective CLI tools)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# Research tools — used by the plan agent (Claude Code) during Step 0 of planning
# Tavily: web search (https://tavily.com)
TAVILY_API_KEY=tvly-xxx

# Firecrawl: page fetch & crawl (https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-yyyy

# Apify: specialized platform scraping (https://apify.com)
APIFY_TOKEN=apify_api_zzzz